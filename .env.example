# Document Management Service — environment template.
# Copy to .env at repo root (which is gitignored) and fill in real values:
#   cp .env.example .env
# Boot the stack from repo root:
#   docker compose -f docker/docker-compose.yml --env-file .env up --build

# === PostgreSQL ===
POSTGRESQL_HOST=postgresql
POSTGRESQL_PORT=5432
POSTGRESQL_DATABASE=challenge
POSTGRESQL_USERNAME=dms
POSTGRESQL_PASSWORD=change_me_postgres
POSTGRESQL_POSTGRES_PASSWORD=change_me_super

# === MinIO ===
# Internal endpoint (service container -> minio container).
MINIO_ENDPOINT=http://minio:9000
# Public endpoint baked into presigned URLs — must be reachable from the HTTP client.
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change_me_minio
# App-level keys; leave blank to fall back to the root user/password (compose handles it).
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=document-bucket

# === Application knobs ===
APP_PRESIGNED_TTL_SECONDS=900
APP_UPLOAD_MAX_SIZE_BYTES=524288000
APP_UPLOAD_ENFORCE_PDF_MAGIC=true

# === JVM ===
# README §"Memory Limitation" — heap fixed at 50 MB.
JAVA_OPTS=-Xmx50m -Xms50m -XX:+ExitOnOutOfMemoryError -XX:MaxMetaspaceSize=64m
